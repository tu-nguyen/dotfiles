    if [[ "$OS_TYPE" == "macos" ]]; then
        alias ls='ls -Gph'
    else
        alias ls='ls -Fph --color=auto --group-directories-first'
    fi

    alias lt='ls -Alht'               # sort by time (newest first
    alias labc='ls -lap'              # sort by alphabetical
fi
